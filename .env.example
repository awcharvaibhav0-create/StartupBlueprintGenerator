# ============================================================
# Startup Blueprint Generator — IBM watsonx.ai Configuration
# ============================================================
# Copy this file to .env and fill in your real credentials.
# NEVER commit the .env file to version control.

# IBM Cloud API Key (IAM)
IBM_API_KEY=your_ibm_api_key_here

# IBM watsonx.ai Project ID
IBM_PROJECT_ID=your_watsonx_project_id_here

# IBM watsonx.ai Service URL
IBM_WATSONX_URL=https://us-south.ml.cloud.ibm.com

# IBM Cloud Region (e.g. us-south, eu-gb, eu-de, jp-tok)
IBM_REGION=us-south

# Model ID for IBM Granite
MODEL_ID=ibm/granite-4-h-small
